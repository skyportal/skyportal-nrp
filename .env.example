# Copy to .env (gitignored) and fill in. These secrets are written into the
# in-cluster `skyportal-secrets` Secret (Google OAuth login + the initial admin).
# See DEPLOYMENT_NOTES.md. The Postgres password is generated at deploy time and
# lives only in the k8s Secret.

# Google OAuth 2.0 client (console.cloud.google.com -> Credentials -> Web app).
# Authorized redirect URI: https://skyportal.nrp-nautilus.io/complete/google-oauth2/
GOOGLE_OAUTH2_KEY=
GOOGLE_OAUTH2_SECRET=

# Email to bootstrap as Super admin (initial_setup.py --adminusername=...).
ADMIN_EMAIL=

# GCN Kafka credentials (https://gcn.nasa.gov/quickstart) -> config gcn.client_id/client_secret.
GCN_CLIENT_ID=
GCN_CLIENT_SECRET=
